{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",

    "lib": ["ES2020"],
    "types": ["node"],

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "noEmit": false
  },
  "include": ["src"]
}